# Production rewrite and header rules for Apache/cPanel Node (Passenger) deployments.
# NOTE: cPanel "Setup Node.js App" injects its own Passenger block
# (between "# DO NOT REMOVE" markers) above this. Leave that block intact.
# Keep this file generic: no private names, person names, or internal notes.

Options -Indexes
RewriteEngine On

# Force HTTPS and the canonical non-www host.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.jrrecyclingsolutionsltd\.com\.bd$ [NC]
RewriteRule ^ https://jrrecyclingsolutionsltd.com.bd%{REQUEST_URI} [R=301,L,NE]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
